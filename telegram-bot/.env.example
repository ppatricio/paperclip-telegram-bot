# Required: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Required: Comma-separated Telegram user IDs that are admins (always allowed)
# Get your ID from @userinfobot on Telegram
ADMIN_USER_IDS=

# Optional: "polling" (default, for local dev) or "webhook" (for production)
BOT_MODE=polling

# Optional: Required when BOT_MODE=webhook
WEBHOOK_URL=
